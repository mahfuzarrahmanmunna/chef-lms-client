generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(STUDENT)
  createdAt DateTime @default(now())
}

model Course {
  id          String   @id @default(uuid())
  title       String
  description String
  price       Float
  thumbnail   String?
  level       String
  duration    String
  createdAt   DateTime @default(now())
  reviews     Review[]
}

model Review {
  id          String   @id @default(uuid())
  studentName String
  rating      Int
  comment     String
  photo       String?
  courseId    String
  course      Course  @relation(fields: [courseId], references: [id])
  createdAt   DateTime @default(now())
}

enum Role {
  ADMIN
  STUDENT
}